# Supabase credentials for the RSVP form (src/pages/Rsvp.tsx).
# Copy this file to `.env.local` (gitignored) and fill in your values.
#
# Find these in your Supabase project: Dashboard > Project Settings > API.
#   - VITE_SUPABASE_URL      -> "Project URL"
#   - VITE_SUPABASE_ANON_KEY -> "Project API keys" > "anon" / "public"
#
# The anon key is meant to be public (it ships in the browser bundle). Security
# comes from row-level security on the `rsvps` table — see supabase/schema.sql.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
