# RSVP backend for the form at /rsvp (src/pages/Rsvp.tsx).
# Copy this file to `.env.local` (gitignored) and fill in your value.
#
# The RSVP form POSTs to a Google Apps Script Web App that stores submissions
# in a Google Sheet and sends confirmation/notification emails. Deploy the
# script (see apps-script/README.md) and paste its Web App URL below.
#
# The URL is public by design — the endpoint only accepts RSVP inserts and
# can't be used to read anyone's data.

VITE_RSVP_ENDPOINT=https://script.google.com/macros/s/XXXXXXXX/exec
